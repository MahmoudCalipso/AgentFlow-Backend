{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ]
  },
  "OpenTelemetry": {
    "ServiceName": "agentflow-backend",
    "OtlpEndpoint": ""
  },
  "AzureOpenAI": {
    "Endpoint": "",
    "Key": "",
    "ChatDeployment": "gpt-4o",
    "EmbeddingsDeployment": "text-embedding-3-small"
  },
  "Qdrant": {
    "Endpoint": "http://localhost:6333",
    "ApiKey": "",
    "Collection": "agentflow-patterns"
  },
  "Redis": {
    "ConnectionString": ""
  },
  "Vault": {
    "Address": "",
    "Token": ""
  },
  "Git": {
    "RepoPath": "./git-graphs",
    "AuthorName": "AgentFlow Bot",
    "AuthorEmail": "bot@agentflow.io"
  },
  "McpServers": [],
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:8080"
      }
    }
  }
}